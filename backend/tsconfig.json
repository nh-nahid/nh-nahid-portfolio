{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": [
      "node"
    ]
  },

  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ],

  "exclude": [
    "dist",
    "node_modules"
  ]
}